#!/usr/bin/env python3
"""
🤖 Claude PR Review Agent - Demo Mode (无需API Key)
用于演示和测试的模拟版本
"""

import os
import sys
import re
import argparse
import subprocess
import json
from pathlib import Path

class PRReviewAgent:
    """PR审查Agent - Demo版本"""
    
    def parse_pr_url(self, url: str) -> tuple:
        """解析PR URL，提取owner, repo, pr_number"""
        pattern = r"github\.com/([^/]+)/([^/]+)/pull/(\d+)"
        match = re.search(pattern, url)
        if not match:
            raise ValueError(f"无效的PR URL: {url}")
        return match.group(1), match.group(2), match.group(3)
    
    def fetch_pr_info(self, owner: str, repo: str, pr_number: str) -> dict:
        """获取PR信息"""
        cmd = f"gh pr view {pr_number} --repo {owner}/{repo} --json title,body,author,files,additions,deletions"
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        
        if result.returncode != 0:
            raise RuntimeError(f"无法获取PR信息: {result.stderr}")
        
        return json.loads(result.stdout)
    
    def fetch_pr_diff(self, owner: str, repo: str, pr_number: str) -> str:
        """获取PR diff"""
        cmd = f"gh pr diff {pr_number} --repo {owner}/{repo}"
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        
        if result.returncode != 0:
            raise RuntimeError(f"无法获取PR diff: {result.stderr}")
        
        return result.stdout
    
    def analyze_pr(self, pr_info: dict, diff: str) -> dict:
        """分析PR（模拟Claude分析）"""
        
        # 简单的启发式分析
        analysis = {
            "summary": "",
            "risks": [],
            "suggestions": [],
            "confidence": "Medium"
        }
        
        # 基于diff大小判断
        additions = pr_info.get('additions', 0)
        deletions = pr_info.get('deletions', 0)
        files_changed = len(pr_info.get('files', []))
        
        analysis["summary"] = f"此PR由 {pr_info.get('author', {}).get('login', 'unknown')} 提交，修改了 {files_changed} 个文件，新增 {additions} 行，删除 {deletions} 行。"
        
        # 检查潜在风险
        if additions > 500:
            analysis["risks"].append("变更量较大，建议分批次审查")
        
        if "TODO" in diff.upper() or "FIXME" in diff.upper():
            analysis["risks"].append("代码中包含 TODO/FIXME 标记")
        
        if "password" in diff.lower() or "secret" in diff.lower() or "api_key" in diff.lower():
            analysis["risks"].append("⚠️ 可能包含敏感信息（password/secret/api_key）")
        
        # 如果没有风险，给个好评
        if not analysis["risks"]:
            analysis["confidence"] = "High"
        
        # 改进建议
        if files_changed > 10:
            analysis["suggestions"].append("建议将大PR拆分为多个小PR，便于审查")
        
        if additions > 0 and deletions == 0:
            analysis["suggestions"].append("纯新增代码，建议确保有充分的测试覆盖")
        
        return analysis
    
    def format_output(self, analysis: dict, pr_url: str, pr_info: dict) -> str:
        """格式化输出为Markdown"""
        output = f"""## 🤖 PR Review Report

**PR**: {pr_url}
**标题**: {pr_info.get('title', 'N/A')}
**作者**: @{pr_info.get('author', {}).get('login', 'unknown')}

### Summary
{analysis['summary']}

### Identified Risks
"""
        if analysis['risks']:
            for risk in analysis['risks']:
                output += f"- ⚠️ {risk}\n"
        else:
            output += "- ✅ 未发现明显风险\n"
        
        output += "\n### Improvement Suggestions\n"
        if analysis['suggestions']:
            for suggestion in analysis['suggestions']:
                output += f"- 💡 {suggestion}\n"
        else:
            output += "- ✅ 代码看起来不错，暂无改进建议\n"
        
        output += f"\n### Confidence Score\n**{analysis['confidence']}**\n"
        
        output += "\n---\n*Generated by Claude PR Review Agent*\n"
        
        return output
    
    def review(self, pr_url: str) -> str:
        """主入口：审查PR"""
        print(f"🔍 正在分析PR: {pr_url}")
        
        # 解析URL
        owner, repo, pr_number = self.parse_pr_url(pr_url)
        print(f"   仓库: {owner}/{repo}, PR #{pr_number}")
        
        # 获取PR信息
        print("📥 获取PR信息...")
        pr_info = self.fetch_pr_info(owner, repo, pr_number)
        print(f"   标题: {pr_info.get('title', 'N/A')}")
        print(f"   作者: @{pr_info.get('author', {}).get('login', 'unknown')}")
        
        # 获取diff
        print("📥 获取PR diff...")
        diff = self.fetch_pr_diff(owner, repo, pr_number)
        print(f"   Diff大小: {len(diff)} 字符")
        
        # 分析
        print("🤖 分析代码...")
        analysis = self.analyze_pr(pr_info, diff)
        
        # 格式化输出
        output = self.format_output(analysis, pr_url, pr_info)
        
        return output


def main():
    parser = argparse.ArgumentParser(description="Claude PR Review Agent (Demo)")
    parser.add_argument("--pr", required=True, help="PR URL (e.g., https://github.com/owner/repo/pull/123)")
    parser.add_argument("--output", "-o", help="输出文件路径（可选）")
    
    args = parser.parse_args()
    
    agent = PRReviewAgent()
    report = agent.review(args.pr)
    
    if args.output:
        with open(args.output, 'w') as f:
            f.write(report)
        print(f"\n✅ 报告已保存到: {args.output}")
    else:
        print("\n" + "=" * 60)
        print(report)
        print("=" * 60)


if __name__ == "__main__":
    main()
