        diff = self.fetch_pr_diff(owner, repo, pr_number)
        
        # 使用Claude分析
        print("🤖 使用Claude分析代码...")
        analysis = self.analyze_with_claude(diff, pr_info)
        
        # 格式化输出
        output = self.format_output(analysis, pr_url)
        
        return output


def main():
    parser = argparse.ArgumentParser(description="Claude PR Review Agent")
    parser.add_argument("--pr", required=True, help="PR URL (e.g., https://github.com/owner/repo/pull/123)")
    parser.add_argument("--output", "-o", help="输出文件路径（可选）")
    
    args = parser.parse_args()
    
    agent = PRReviewAgent()
    report = agent.review(args.pr)
    
    if args.output:
        with open(args.output, 'w') as f:
            f.write(report)
        print(f"\n✅ 报告已保存到: {args.output}")
    else:
        print("\n" + "=" * 60)
        print(report)
        print("=" * 60)


if __name__ == "__main__":
    main()
